{
  "expo": {
    "name": "readIQ",
    "slug": "readiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "readiq",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F7FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.holawale.readiq"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/brand/readiq-iqmark.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "readIQ uses the camera to scan pages of your notes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "readIQ needs photo access so you can add a note from an image."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "readIQ records your lectures so it can transcribe them into notes."
        }
      ],
      "expo-sqlite",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e279512e-6222-41d4-b652-041ed0bd9215"
      }
    },
    "owner": "holawale",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e279512e-6222-41d4-b652-041ed0bd9215"
    },
    "ios": {}
  }
}
