# readIQ — BTL Runtime credentials
# Copy this file to ".env" and fill in your scoped hackathon values.
# The .env file is git-ignored and must NEVER be committed.
# These vars are read ONLY in src/lib/btl.ts.

# Scoped BTL Runtime API key (issued for the hackathon)
EXPO_PUBLIC_BTL_API_KEY=

# BTL Runtime base URL, e.g. https://api.badtheorylabs.com/v1
EXPO_PUBLIC_BTL_BASE_URL=

# --- Record transcription (Whisper) ----------------------------------------
# BTL cannot transcribe audio, so lecture Record uses a Whisper-compatible API
# directly (read ONLY in src/lib/transcription.ts). Leave the key blank to disable
# auto-transcribe — Record then falls back to a manual, editable transcript.
#
# Option A — OpenAI (paid): get a key at https://platform.openai.com/api-keys
#   EXPO_PUBLIC_OPENAI_API_KEY=sk-...
#
# Option B — Groq (free tier, recommended for the hackathon):
#   get a key at https://console.groq.com/keys, then set all three:
#   EXPO_PUBLIC_OPENAI_API_KEY=gsk_...
#   EXPO_PUBLIC_OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   EXPO_PUBLIC_OPENAI_STT_MODEL=whisper-large-v3
EXPO_PUBLIC_OPENAI_API_KEY=
# EXPO_PUBLIC_OPENAI_BASE_URL=
# EXPO_PUBLIC_OPENAI_STT_MODEL=
